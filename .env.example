# ─────────────────────────────────────────────────────────────────────────────
# EA Coach — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs avant de démarrer.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de données (OBLIGATOIRE) ─────────────────────────────────────────────
# URL de connexion MySQL (PlanetScale, Railway MySQL, Render MySQL, etc.)
# Format : mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://user:password@localhost:3306/eacoach

# ── Sécurité des sessions (OBLIGATOIRE) ───────────────────────────────────────
# Clé secrète pour signer les cookies JWT admin.
# Générez une valeur aléatoire forte : openssl rand -hex 32
JWT_SECRET=changez_moi_en_production_valeur_aleatoire_forte

# ── Clé de configuration admin (OBLIGATOIRE) ─────────────────────────────────
# Clé requise pour créer le premier compte admin via /admin/setup.
# Choisissez une valeur secrète que vous seul connaissez.
ADMIN_SETUP_KEY=votre_cle_secrete_admin_setup

# ── Environnement (OBLIGATOIRE) ───────────────────────────────────────────────
NODE_ENV=production

# ── Port (OPTIONNEL) ──────────────────────────────────────────────────────────
# Railway et Render injectent automatiquement la variable PORT.
# En local, vous pouvez définir un port personnalisé.
# PORT=3000

# ── Web3Forms (OPTIONNEL) ─────────────────────────────────────────────────────
# Clé API Web3Forms pour le formulaire de contact.
# Obtenez votre clé sur https://web3forms.com (gratuit)
VITE_WEB3FORMS_KEY=votre_cle_web3forms
